PORT=5000
NODE_ENV=development

# Databases
MONGO_URI=mongodb://localhost:27017/queuekiller
DATABASE_URL=postgresql://user:password@localhost:5432/queuekiller

# Redis
REDIS_URL=redis://localhost:6379
REDISPREFIX=app:

# JWT secret (replace with a secure random string)
JWT_SECRET=change_me_jwt_secret

# Initial admin credentials (change immediately)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_password

# Razorpay keys
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=your_actual_key_secret

